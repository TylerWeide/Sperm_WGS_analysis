#!/bin/bash
#SBATCH --job-name=merged_stats
#SBATCH --output=merged_stats.out
#SBATCH --error=merged_stats.err
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=6
#SBATCH --mem=100G
#SBATCH --time=24:00:00
#SBATCH --mail-user=tjweide@iastate.edu
#SBATCH --mail-type=END,FAIL

module load bcftools

VCF_DIR="/work/ABG/tjweide/Genomics/Mito_WGS_2025/VCF/Genotyped/Filtered/Merged/Final"
OUT_DIR="/work/ABG/tjweide/Genomics/Mito_WGS_2025/VCF/Stats/Merged"

mkdir -p "$OUT_DIR"

for ID in 1 2 3; do
    VCF="${VCF_DIR}/${ID}.final.vcf.gz"

    # Summary statistics
    bcftools stats "$VCF" > "${OUT_DIR}/${ID}.stats.txt" &

    # Extract useful fields: CHROM, POS, REF, ALT, GT, GQ, DP, AD
    bcftools query -f '%CHROM\t%POS\t%REF\t%ALT[\t%GT\t%GQ\t%DP\t%AD]\n' "$VCF" > "${OUT_DIR}/${ID}.genotype_details.tsv" &

    # Compute basic allele frequency (for hets)
    bcftools query -i 'GT="het"' -f '%CHROM\t%POS\t%REF\t%ALT[\t%AD]\n' "$VCF" \
    | awk '{
        split($5,ad,",");
        total=ad[1]+ad[2];
        if (total > 0) {
            af = ad[2]/total;
            print $1,$2,$3,$4,ad[1],ad[2],af
        }
    }' OFS='\t' > "${OUT_DIR}/${ID}.allele_freq.tsv" &

done

wait

