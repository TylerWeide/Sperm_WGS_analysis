#!/bin/bash
#SBATCH --job-name=individual_stats
#SBATCH --output=individual_stats.out
#SBATCH --error=individual_stats.err
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=6
#SBATCH --mem=120G
#SBATCH --time=24:00:00
#SBATCH --mail-user=tjweide@iastate.edu
#SBATCH --mail-type=END,FAIL

# NOTE: Paths are specific to ISU HPC environment (/work/ABG/...).
# Update paths if running on a different system.

module load bcftools

VCF_DIR="/work/ABG/tjweide/Genomics/Mito_WGS_2025/VCF/Genotyped/Filtered/Individual/Final"
OUT_DIR="/work/ABG/tjweide/Genomics/Mito_WGS_2025/VCF/Stats/Individual"

mkdir -p "$OUT_DIR"

for ID in 1-1 1-2 2-1 2-2 3-1 3-2; do
    VCF="${VCF_DIR}/${ID}.final.vcf.gz"

    # Summary stats (bcftools stats)
    bcftools stats "$VCF" > "${OUT_DIR}/${ID}.stats.txt" &

    # Genotype details: CHROM, POS, REF, ALT, GT, GQ, DP, AD
    bcftools query -f '%CHROM\t%POS\t%REF\t%ALT[\t%GT\t%GQ\t%DP\t%AD]\n' "$VCF" \
        > "${OUT_DIR}/${ID}.genotype_details.tsv" &

    # Allele frequency estimate from AD field (het sites only)
    bcftools query -i 'GT="het"' -f '%CHROM\t%POS\t%REF\t%ALT[\t%AD]\n' "$VCF" \
    | awk '{
        split($5,ad,",");
        total=ad[1]+ad[2];
        if (total > 0) {
            af = ad[2]/total;
            print $1,$2,$3,$4,ad[1],ad[2],af
        }
    }' OFS='\t' > "${OUT_DIR}/${ID}.allele_freq.tsv" &

done

wait

